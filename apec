<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>APEC Login Page</title>

  <style>
    body {
      margin: 0;
      font-family: Arial, sans-serif;
      background: linear-gradient(to right, #ff4b2b, #ff416c);
      display: flex;
      justify-content: center;
      align-items: center;
      height: 100vh;
    }

    .login-box {
      background: white;
      padding: 30px;
      border-radius: 15px;
      width: 340px;
      text-align: center;
      box-shadow: 0 0 20px rgba(0,0,0,0.2);
    }

    .login-box img {
      width: 120px;
      margin-bottom: 10px;
    }

    .login-box h2 {
      margin-bottom: 20px;
      color: #b30000;
      font-size: 18px;
    }

    .login-box input {
      width: 90%;
      padding: 10px;
      margin: 8px 0;
      border: 1px solid #ccc;
      border-radius: 8px;
    }

    .login-box button {
      width: 95%;
      padding: 10px;
      background: #ff416c;
      color: white;
      border: none;
      border-radius: 8px;
      cursor: pointer;
      margin-top: 10px;
      font-size: 15px;
    }

    .login-box button:hover {
      background: #e6004c;
    }

    .footer {
      margin-top: 10px;
      font-size: 12px;
      color: gray;
    }
  </style>
</head>

<body>

  <div class="login-box">

    <!-- APEC LOGO (your uploaded image) -->
    <img src="afce0522-bc81-4280-803e-dcb67bae76fb.png" alt="APEC Logo">

    <h2>Adhiparasakthi Engineering College</h2>

    <form>
      <input type="text" placeholder="Username" required>
      <input type="password" placeholder="Password" required>
      <button type="submit">Login</button>
    </form>

    <div class="footer">
      © APEC Login Portal
    </div>

  </div>

</body>
</html>
